---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import Button from '../../../../components/Button.astro';
import { withBase } from '../../../../utils/withBase.js';
import { getMaterials } from '../../../../data/materials.js';

export function getStaticPaths() {
  return getMaterials('A1', 1).map((material) => ({
    params: { slug: material.slug },
    props: { material },
  }));
}

const { material } = Astro.props;
const available = material.status === 'verfügbar';

// Vorschaubild: wird aus der PDF erzeugt und liegt unter
// public/images/thumbs/<slug>.png (siehe README → «Neues Material»).
const thumbUrl = withBase(`/images/thumbs/${material.slug}.png`);

// Weiteres Material aus demselben Heft (max. 3 Vorschläge)
const related = getMaterials('A1', 1)
  .filter((m) => m.slug !== material.slug)
  .slice(0, 3);
---

<BaseLayout title={material.title} description={material.description}>
  <main class="container">
    <Breadcrumb
      items={[
        { label: 'A1', href: withBase('/a1/') },
        { label: 'Heft 1', href: withBase('/a1/heft-1/') },
        { label: 'Zusatzmaterialien', href: withBase('/a1/heft-1/materialien/') },
        { label: material.title },
      ]}
    />

    <article class="material">
      {
        available && (
          <a class="preview" href={withBase(material.fileUrl)} aria-label="PDF öffnen">
            <img src={thumbUrl} alt={`Vorschau: ${material.title}`} loading="eager" />
          </a>
        )
      }

      <div class="info">
        <div class="meta">
          <span class="badge badge--type">{material.type}</span>
          <span class="badge badge--kind">{material.kind}</span>
        </div>
        <h1>{material.title}</h1>
        <p class="block">Englisch A1 · Heft 1 · {material.block}</p>
        <p class="lead">{material.description}</p>

        {
          available ? (
            <div class="cta">
              <Button href={withBase(material.fileUrl)} block download>
                PDF herunterladen
              </Button>
              <a class="open-link" href={withBase(material.fileUrl)}>
                oder im Browser öffnen →
              </a>
            </div>
          ) : (
            <p class="note">
              Dieses Material ist in Arbeit und wird hier in Kürze als PDF verfügbar
              sein. Diese Seite bleibt die feste Adresse dafür – der QR-Code im Heft
              führt immer hierher.
            </p>
          )
        }
      </div>
    </article>

    {
      related.length > 0 && (
        <section class="related">
          <h2>Weiteres Material zu Heft 1</h2>
          <ul>
            {related.map((m) => (
              <li>
                <a href={withBase(`/a1/heft-1/materialien/${m.slug}/`)}>{m.title}</a>
                <span class="related-block">{m.block}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="back">
      <a href={withBase('/a1/heft-1/materialien/')}>← Zurück zur Übersicht</a>
    </p>
  </main>
</BaseLayout>

<style>
  .material {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) 1fr;
    gap: 2.25rem;
    align-items: start;
    margin-bottom: 1rem;
  }

  .preview {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 6px 20px rgba(34, 57, 102, 0.1);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }

  .preview:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 26px rgba(34, 57, 102, 0.16);
  }

  .preview img {
    display: block;
    width: 100%;
    height: auto;
  }

  .info h1 {
    margin-top: 0.4rem;
  }

  .meta {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.8rem;
  }

  .block {
    color: var(--muted);
    font-size: 0.92rem;
    margin-bottom: 0.6rem;
  }

  .cta {
    margin-top: 1.5rem;
  }

  .open-link {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 0.95rem;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .material {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .preview {
      max-width: 320px;
    }

    /* Mobil: Download-Button direkt unter das Bild, Infos danach */
    .info {
      display: flex;
      flex-direction: column;
    }

    .info .cta {
      order: -1;
      margin-top: 0;
      margin-bottom: 1.4rem;
    }

    .open-link {
      display: block;
      text-align: center;
    }
  }

  .related {
    margin-top: 3rem;
  }

  .related h2 {
    font-size: 1.2rem;
  }

  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .related li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .related-block {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .back {
    margin-top: 2.5rem;
  }
</style>
