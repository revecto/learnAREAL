---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import Button from '../../../../components/Button.astro';
import { withBase } from '../../../../utils/withBase.js';
import { getMaterials } from '../../../../data/materials.js';

export function getStaticPaths() {
  return getMaterials('A1', 1).map((material) => ({
    params: { slug: material.slug },
    props: { material },
  }));
}

const { material } = Astro.props;
const available = material.status === 'verfügbar';

// Weiteres Material aus demselben Heft (max. 3 Vorschläge)
const related = getMaterials('A1', 1)
  .filter((m) => m.slug !== material.slug)
  .slice(0, 3);
---

<BaseLayout title={material.title} description={material.description}>
  <main class="container">
    <Breadcrumb
      items={[
        { label: 'A1', href: withBase('/a1/') },
        { label: 'Heft 1', href: withBase('/a1/heft-1/') },
        { label: 'Zusatzmaterialien', href: withBase('/a1/heft-1/materialien/') },
        { label: material.title },
      ]}
    />

    <div class="meta">
      <span class="badge badge--type">{material.type}</span>
      <span class="badge badge--kind">{material.kind}</span>
    </div>
    <h1>{material.title}</h1>
    <p class="lead">{material.description}</p>
    <p class="block">Gehört zu: <strong>{material.block}</strong></p>

    {
      available ? (
        <p>
          <Button href={withBase(material.fileUrl)}>PDF herunterladen</Button>
        </p>
      ) : (
        <p class="note">
          Dieses Material ist in Arbeit und wird hier in Kürze als PDF verfügbar sein.
          Diese Seite bleibt die feste Adresse dafür – der QR-Code im Heft führt immer
          hierher.
        </p>
      )
    }

    {
      related.length > 0 && (
        <section class="related">
          <h2>Weiteres Material zu Heft 1</h2>
          <ul>
            {related.map((m) => (
              <li>
                <a href={withBase(`/a1/heft-1/materialien/${m.slug}/`)}>{m.title}</a>
                <span class="related-block">{m.block}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="back">
      <a href={withBase('/a1/heft-1/materialien/')}>← Zurück zur Übersicht</a>
    </p>
  </main>
</BaseLayout>

<style>
  .meta {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.8rem;
  }

  .block {
    color: var(--muted);
  }

  .related {
    margin-top: 3rem;
  }

  .related h2 {
    font-size: 1.2rem;
  }

  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .related li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .related-block {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .back {
    margin-top: 2.5rem;
  }
</style>
