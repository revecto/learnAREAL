---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { withBase } from '../utils/withBase.js';

const heroImage = withBase('/images/hero-banner.jpg');
const videoUrl = withBase('/images/Video-Lernareal.mp4');
const videoPoster = withBase('/images/video-poster.jpg');

// Auszüge aus den Zusatzmaterialien (Vorschaubilder der PDFs)
const zusatzThumbs = [
  { src: '/images/thumbs/to-be-alle-formen.png', label: 'to be – alle Formen' },
  { src: '/images/thumbs/wh-fragewoerter.png', label: 'WH-Fragewörter' },
  { src: '/images/thumbs/this-that-these-those.png', label: 'this / that / these / those' },
];
---

<BaseLayout description="learnAREAL – Englisch verstehen, statt Regeln nur auswendig zu lernen. Lernkarten, Lernposter, Lerncoach-Tipps und Zusatzmaterialien zu den learnAREAL-Arbeitsheften.">
  <section class="hero" style={`background-image:url('${heroImage}')`}>
    <div class="container">
      <div class="hero-content">
        <h1>learnAREAL</h1>
        <p class="claim">Englisch verstehen, statt Regeln nur auswendig zu lernen.</p>
        <p class="lead">
          Englische Sprachmuster Schritt für Schritt erkennen und verstehen. Immer mit
          kurzen Erklärungen, klaren Beispielen und hilfreichen Lerncoach-Tipps.
        </p>
        <p class="hero-audience">Für Erwachsene, Wiedereinsteiger und Selbstlerner.</p>
        <Button href={withBase('/a1/')} variant="secondary">Zu Englisch A1</Button>
      </div>
    </div>
  </section>

  <main class="container">
    <!-- Das System -->
    <section class="section">
      <SectionHeading eyebrow="Das System">So lernst du mit learnAREAL</SectionHeading>

      <ol class="prozess" aria-label="Lernprozess: Erkennen, Verstehen, Anwenden">
        <li class="stage"><span class="n">1</span> Erkennen</li>
        <li class="arrow" aria-hidden="true">→</li>
        <li class="stage"><span class="n">2</span> Verstehen</li>
        <li class="arrow" aria-hidden="true">→</li>
        <li class="stage"><span class="n">3</span> Anwenden</li>
      </ol>

      <p class="lead">
        Das Konzept learnAREAL arbeitet bewusst mit drei festen Elementen, um deinen
        Lernprozess kleinschrittig und klar nachvollziehbar zu gestalten. Die Lernkarten,
        Lernposter und Lerncoach-Tipps sind so aufgebaut, dass du natürlich und intuitiv
        auf deinem Lernweg begleitet wirst.
      </p>

      <ul class="features">
        <li>
          <h3>Lernkarten</h3>
          <p>
            Jede Lernkarte erklärt einen kleinen Lernschritt – mit einer Erklärung und
            drei Beispielen. Wichtige Sprachmuster sind klar hervorgehoben.
          </p>
          <div class="placeholder" aria-hidden="true">Bild folgt</div>
        </li>
        <li>
          <h3>Lernposter</h3>
          <p>
            Grössere Themen starten mit einem Lernposter: zuerst der Überblick, dann die
            einzelnen Lernkarten.
          </p>
          <div class="placeholder" aria-hidden="true">Bild folgt</div>
        </li>
        <li>
          <h3>Lerncoach-Tipps</h3>
          <p>
            Kurze Hinweise dort, wo typische Fragen oder Unsicherheiten entstehen – wie
            ein Lerncoach, der dich durchs Heft begleitet.
          </p>
          <div class="placeholder" aria-hidden="true">Bild folgt</div>
        </li>
      </ul>
    </section>

    <!-- Zusatzmaterialien -->
    <section class="section">
      <SectionHeading eyebrow="Zusatzmaterialien">Vertiefung genau dort, wo du sie brauchst</SectionHeading>
      <div class="split">
        <div>
          <p>
            Zu vielen Themen im Heft gibt es ergänzende Übersichten, Tabellen und
            Vertiefungen. Im gedruckten Heft erreichst du sie über einen QR-Code, im
            E-Book über einen direkten Link – jeweils genau an der Stelle, an der das
            Thema behandelt wird.
          </p>
          <p>
            So bekommst du mehr Beispiele und kompakte Übersichten, ohne dass das Heft
            überladen wird. Das Heft bleibt schlank und konzentriert; die Vertiefung
            holst du dir, wenn du sie wirklich brauchst.
          </p>
          <p>
            <Button href={withBase('/a1/heft-1/materialien/')}>Zu den Zusatzmaterialien</Button>
          </p>
        </div>
        <ul class="zusatz-previews" aria-hidden="true">
          {
            zusatzThumbs.map((t) => (
              <li>
                <img src={withBase(t.src)} alt="" loading="lazy" />
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Die Idee / Video -->
    <section class="section">
      <SectionHeading eyebrow="Die Idee">Die Grundidee hinter learnAREAL</SectionHeading>
      <p class="lead">
        Das folgende Video erklärt die Grundidee hinter learnAREAL: Lernen funktioniert
        oft besser, wenn grosse Themen in kleine, nachvollziehbare Schritte aufgeteilt
        werden. Jede Lernkarte soll ein kleines Erfolgserlebnis ermöglichen und den
        nächsten Schritt leichter machen.
      </p>
      <div class="video">
        <video
          controls
          preload="none"
          poster={videoPoster}
          title="Video: Die Grundidee hinter learnAREAL"
        >
          <source src={videoUrl} type="video/mp4" />
          Dein Browser kann dieses Video nicht abspielen.
        </video>
      </div>
    </section>

    <!-- Was learnAREAL anders macht -->
    <section class="section">
      <SectionHeading eyebrow="Der Ansatz">Was learnAREAL anders macht</SectionHeading>
      <p>
        Klassische Grammatikhefte beginnen oft mit langen Regeln. learnAREAL geht anders
        vor: Du siehst zuerst ein klares Sprachmuster, verstehst es an einfachen
        Beispielen und baust dein Wissen danach Schritt für Schritt aus. Das macht die
        Inhalte übersichtlicher – und hilft besonders, wenn du Grammatik besser über
        Beispiele, Wiederholungen und klare Strukturen verstehst.
      </p>
      <p>
        Ein weiterer wichtiger Punkt ist der Vergleich zwischen Deutsch und Englisch.
        learnAREAL zeigt typische Unterschiede und Gemeinsamkeiten bewusst auf. So
        verstehst du besser, warum Englisch manchmal anders funktioniert als eine direkte
        Übersetzung aus dem Deutschen.
      </p>
    </section>

    <!-- Das Sprachhaus -->
    <section class="section">
      <SectionHeading eyebrow="Der Lernweg">Das Sprachhaus</SectionHeading>
      <div class="split">
        <div>
          <p>
            learnAREAL arbeitet mit dem Bild eines Sprachhauses. Es zeigt, dass Sprache
            nicht auf einmal gelernt wird, sondern Ebene für Ebene aufgebaut werden kann.
            Die Niveaus A1 bis B2 orientieren sich am Gemeinsamen Europäischen
            Referenzrahmen (GER). Jedes Niveau steht für einen wichtigen Abschnitt auf
            dem Lernweg und bildet die Grundlage für das nächste.
          </p>
          <p>
            A1 bildet die Treppen zum Haus – hier entstehen die ersten Grundlagen. Mit A2
            beginnt das Erdgeschoss, darauf baut B1 als weiterer Stock auf, und mit B2
            wird das Sprachhaus mit dem Dachgeschoss vervollständigt.
          </p>
          <p>
            So wird dein Lernweg sichtbar: Du siehst, wo du gerade stehst, was du schon
            geschafft hast und welcher Schritt als Nächstes kommt. Jedes Niveau baut auf
            dem vorherigen auf – wer die Grundlagen sicher versteht, erreicht den nächsten
            Abschnitt leichter.
          </p>
          <p>
            Die Reihe wächst weiter: Nach A1 folgen A2, B1 und B2. Jedes Heft erscheint
            digital und als gedruckte Ausgabe.
          </p>
        </div>
        <img
          class="haus-img"
          src={withBase('/images/sprachhaus.jpg')}
          alt="Das Sprachhaus: A1 bildet die Treppen mit den 8 Heften, darauf folgen A2 (Erdgeschoss), B1 (1. Stock) und B2 (Dachgeschoss)."
          loading="lazy"
        />
      </div>
      <p class="sh-cta">
        <Button href={withBase('/a1/')}>Zu Englisch A1</Button>
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  /* Hero mit Hintergrundbild */
  .hero {
    position: relative;
    background-size: cover;
    background-position: center right;
    border-bottom: 1px solid var(--border);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(34, 57, 102, 0.82) 0%,
      rgba(39, 73, 138, 0.6) 45%,
      rgba(58, 112, 191, 0.3) 100%
    );
  }

  .hero .container {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 40rem;
    padding: 4.5rem 0;
  }

  .hero h1,
  .hero .claim {
    color: #fff;
  }

  .hero .claim {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5em;
  }

  .hero .lead {
    color: #eaf2fb;
  }

  .hero-audience {
    color: #dbe7f7;
    font-size: 0.98rem;
    margin: 0 0 1.4rem;
  }

  /* Prozessdiagramm */
  .prozess {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0 0 1.5rem;
    padding: 0;
    list-style: none;
  }

  .prozess .stage {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--blue-soft);
    color: var(--navy);
    font-weight: 700;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
  }

  .prozess .stage .n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    font-size: 0.85rem;
  }

  .prozess .arrow {
    color: var(--green);
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1;
  }

  /* Feature-Kacheln */
  .features {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .features li {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.4rem;
  }

  .features p {
    margin: 0 0 1rem;
    color: var(--muted);
    font-size: 0.98rem;
  }

  .placeholder {
    margin-top: auto;
    aspect-ratio: 4 / 3;
    border: 1px dashed var(--border);
    border-radius: 8px;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }

  /* Split-Layout */
  .split {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .split > div {
    flex: 1 1 24rem;
  }

  .split img.haus-img {
    flex: 0 0 auto;
    max-width: 340px;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  /* Zusatzmaterial-Vorschauen */
  .zusatz-previews {
    flex: 0 0 auto;
    display: flex;
    gap: 0.6rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .zusatz-previews li:nth-child(2) {
    margin-top: 1.4rem;
  }

  .zusatz-previews img {
    width: 110px;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  /* GER-Badge inline */
  .ger-line {
    margin-bottom: 1.25rem;
  }

  .ger-inline {
    width: 92px;
    height: auto;
  }

  /* Video */
  .video {
    position: relative;
    aspect-ratio: 16 / 9;
    max-width: 760px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }

  .video video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: cover;
    background: #000;
  }

  .sh-cta {
    margin-top: 1.5rem;
  }

  @media (max-width: 600px) {
    .hero {
      background-position: center;
    }

    .hero::before {
      background: linear-gradient(
        180deg,
        rgba(34, 57, 102, 0.8),
        rgba(34, 57, 102, 0.72)
      );
    }

    .hero-content {
      padding: 3rem 0;
    }

    .zusatz-previews img {
      width: 92px;
    }

    .prozess {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .prozess .stage {
      width: 100%;
      max-width: 260px;
      justify-content: center;
    }

    .prozess .arrow {
      transform: rotate(90deg);
    }
  }
</style>
