---
// variant: "primary" | "secondary"
// block: true  → volle Breite (mobil-freundlicher CTA)
const { href, variant = 'primary', block = false, download = false } = Astro.props;
const cls = `btn btn--${variant}${block ? ' btn--block' : ''}`;
---

<a class={cls} href={href} {...(download ? { download: '' } : {})}><slot /></a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease;
  }

  .btn--block {
    width: 100%;
  }

  .btn:hover {
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .btn {
      width: 100%;
    }
  }

  .btn--primary {
    background: var(--blue);
    color: #fff;
  }

  .btn--primary:hover {
    background: var(--blue-dark);
  }

  .btn--secondary {
    background: var(--surface);
    color: var(--blue-dark);
    border: 1px solid var(--border);
  }

  .btn--secondary:hover {
    border-color: var(--blue);
  }
</style>
