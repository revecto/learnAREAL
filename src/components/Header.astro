---
import { withBase } from '../utils/withBase.js';
import Logo from './Logo.astro';
---

<header class="site-header">
  <div class="container inner">
    <a class="brand" href={withBase('/')} aria-label="learnAREAL – Startseite">
      <Logo height={34} />
    </a>

    <div class="nav-wrap">
      <nav aria-label="Hauptnavigation">
        <a href={withBase('/a1/')}>Englisch A1</a>
        <span class="soon" title="erscheint später">A2</span>
        <span class="soon" title="erscheint später">B1</span>
        <span class="soon" title="erscheint später">B2</span>
      </nav>

      <div class="contact">
        <a
          href="https://www.revecto.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Website revecto.com"
          title="www.revecto.com"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3 12h18"></path>
            <ellipse cx="12" cy="12" rx="4" ry="9"></ellipse>
          </svg>
        </a>
        <a
          href="mailto:info@revecto.com"
          aria-label="E-Mail an info@revecto.com"
          title="info@revecto.com"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
        </a>
        <a
          href="https://wa.me/50670217432"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          title="WhatsApp"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.2 4.79 1.2h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 1.8c2.16 0 4.18.84 5.71 2.37a8.06 8.06 0 0 1 2.37 5.74c0 4.46-3.63 8.09-8.1 8.09-1.52 0-3.01-.42-4.3-1.22l-.31-.18-3.12.82.83-3.04-.2-.32a8.03 8.03 0 0 1-1.26-4.35c0-4.46 3.63-8.09 8.08-8.09zm-4.6 4.34c-.21 0-.55.08-.84.39-.29.31-1.1 1.08-1.1 2.62 0 1.55 1.13 3.04 1.29 3.25.16.21 2.22 3.39 5.38 4.62 2.63 1.02 3.17.82 3.74.77.57-.05 1.84-.75 2.1-1.48.26-.73.26-1.35.18-1.48-.08-.13-.29-.21-.6-.37-.31-.16-1.84-.91-2.13-1.01-.29-.1-.5-.16-.71.16-.21.31-.81 1.01-.99 1.22-.18.21-.37.24-.68.08-.31-.16-1.31-.48-2.5-1.54-.92-.82-1.54-1.84-1.72-2.15-.18-.31-.02-.48.14-.63.14-.14.31-.37.47-.55.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.69-1.7-.96-2.32-.25-.6-.5-.52-.69-.53l-.59-.01z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }

  .brand:hover {
    text-decoration: none;
  }

  .nav-wrap {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--blue-dark);
    font-weight: 600;
    font-size: 0.98rem;
  }

  nav a:hover {
    color: var(--blue);
    text-decoration: none;
  }

  .soon {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.98rem;
    opacity: 0.55;
    cursor: default;
  }

  .contact {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-left: 1rem;
    border-left: 1px solid var(--border);
  }

  .contact a {
    color: var(--blue-dark);
    display: inline-flex;
  }

  .contact a:hover {
    color: var(--blue);
    text-decoration: none;
  }

  .contact svg {
    width: 20px;
    height: 20px;
    display: block;
  }

  @media (max-width: 560px) {
    .inner {
      flex-wrap: wrap;
    }

    .nav-wrap {
      width: 100%;
      justify-content: space-between;
      gap: 0.75rem 1rem;
    }

    .contact {
      padding-left: 0;
      border-left: 0;
    }
  }
</style>
