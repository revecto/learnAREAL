---
import { withBase } from '../utils/withBase.js';
import Logo from './Logo.astro';
---

<header class="site-header">
  <div class="container inner">
    <a class="brand" href={withBase('/')} aria-label="learnAREAL – Startseite">
      <Logo height={34} />
    </a>
    <nav aria-label="Hauptnavigation">
      <a href={withBase('/a1/')}>Englisch A1</a>
      <span class="soon" title="erscheint später">A2</span>
      <span class="soon" title="erscheint später">B1</span>
      <span class="soon" title="erscheint später">B2</span>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }

  .brand:hover {
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--blue-dark);
    font-weight: 600;
    font-size: 0.98rem;
  }

  nav a:hover {
    color: var(--blue);
    text-decoration: none;
  }

  .soon {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.98rem;
    opacity: 0.55;
    cursor: default;
  }
</style>
